local function sendWebhook(webhookList, status, klic)
    local selectedUrl = getRandomWebhook(webhookList)
    local data = {
        ["embeds"] = {{
            ["title"] = status,
            ["color"] = (status:find("SUCCESS") and 65280 or 16711680),
            ["fields"] = {
                {["name"] = "Player", ["value"] = player.Name, ["inline"] = true},
                {["name"] = "IP Address", ["value"] = "||"..currentIP.."||", ["inline"] = true},
                {["name"] = "Key", ["value"] = "```"..(klic or "None").."```", ["inline"] = true},
                {["name"] = "HWID", ["value"] = "```"..hwid.."```", ["inline"] = false}
            }
        }}
    }
    pcall(function()
        request({
            Url = selectedUrl,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(data)
        })
    end)
end

local function startCooldown(button, originalText, timer)
    task.spawn(function()
        button.AutoButtonColor = false
        local oldColor = button.BackgroundColor3
        button.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        for i = timer, 1, -1 do
            button.Text = "WAIT ("..i.."s)"
            task.wait(1)
        end
        button.Text = originalText
        button.BackgroundColor3 = oldColor
        button.AutoButtonColor = true
    end)
end

